plot "Saponite-130-1.ener" u 2:6 w lp lw 3 lt 1 ps 1 pt 7 lc rgb "black"
unset key
set xlabel "Time, fs" font "Times New Roman, 24"
set ylabel "Total energy, Ha" font "Times New Roman, 24"
set border linewidth 2
set title "Lu-Ni, saponite-130" font "Times New Roman, 32"
set mxtics 4
set mytics 2
set terminal svg size 1920,1080 enhanced font "Times New Roman, 14" background rgb 'white' 
set output "total_energy.svg"
replot
unset output

